# Echo Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# ANTHROPIC CLAUDE API
# ============================================================================
# Get your API key from: https://console.anthropic.com/
# Used for humanizing anonymized thoughts into natural language
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# ELASTICSEARCH CONFIGURATION
# ============================================================================
# Elastic Cloud credentials for storing anonymized thoughts
# Get from: https://cloud.elastic.co/
# IMPORTANT: Elasticsearch only receives anonymized text - never raw thoughts
ELASTIC_CLOUD_ID=your-deployment-name:dXMtY2VudHJhbDEuZ2NwLmNsb3VkLmVzLmlv...
ELASTIC_API_KEY=your-api-key

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Secret key for signing JWT tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CRITICAL: Change this in production
JWT_SECRET=your-secret-key-here

# ============================================================================
# OLLAMA SLM CONFIGURATION
# ============================================================================
# Host URL for local Ollama instance running the anonymizer model
# The anonymizer MUST run before any text is sent to external APIs
# Model: eternisai/anonymizer-0.6b-q4_k_m-gguf
OLLAMA_HOST=http://localhost:11434

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string for account data (email + password hash only)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://echo_user:echo_password@localhost:5432/echo

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8000

# ============================================================================
# PRIVACY NOTES
# ============================================================================
# 1. Raw thought text is NEVER logged or persisted on the server
# 2. The anonymizer runs FIRST - raw text is discarded immediately after
# 3. Claude only receives anonymized text, never raw user input
# 4. Elasticsearch stores anonymized thoughts with NO user identifiers
# 5. Account data (email + bcrypt hash) is stored separately from thoughts
# 6. Theme categories link accounts to emotional topics, NOT raw text
# 7. "What helped" advice goes through the same anonymization pipeline
