{
  "project_type": "monorepo",
  "services": {
    "frontend": {
      "path": "frontend",
      "tech_stack": ["typescript", "nextjs", "tailwindcss", "framer-motion"],
      "port": 3000,
      "dev_command": "npm run dev",
      "build_command": "npm run build",
      "test_command": "npx tsc --noEmit && npm run build",
      "e2e_command": "npx playwright test"
    },
    "backend": {
      "path": "backend",
      "tech_stack": ["python", "fastapi", "pydantic"],
      "port": 8000,
      "dev_command": "uvicorn main:app --reload",
      "test_command": "pytest"
    }
  },
  "infrastructure": {
    "docker": true,
    "docker_compose": "infra/docker-compose.yml",
    "database": "elasticsearch"
  },
  "conventions": {
    "linter": "eslint (frontend), ruff (backend)",
    "formatter": "prettier (frontend), black (backend)",
    "testing": "playwright (e2e frontend), pytest (backend)",
    "typescript": "strict mode"
  }
}
