# Echo — Environment Variables
# Copy this file to .env and fill in your actual values
# Used by docker-compose and local development

# ============================================================================
# NANOGPT API (Qwen3.5-122B-A10B for humanisation)
# ============================================================================
# Get your API key from: https://nano-gpt.com/
# Used for humanizing anonymized thoughts into natural language
# IMPORTANT: The API only ever receives anonymized text, never raw user input
NANOGPT_API_KEY=sk-nano-6652ed48-7537-4f3b-81ea-9d78c2af76dd

# ============================================================================
# ELASTICSEARCH CONFIGURATION
# ============================================================================
# Elastic Cloud credentials for storing anonymized thoughts
# Get from: https://cloud.elastic.co/
# IMPORTANT: Elasticsearch only receives anonymized text — never raw thoughts
# For Elastic Serverless: leave ELASTIC_CLOUD_ID blank, set ELASTIC_HOST to your endpoint URL
ELASTIC_CLOUD_ID=
ELASTIC_HOST=https://my-elasticsearch-project-a6f462.es.asia-southeast1.gcp.elastic.cloud:443
ELASTIC_API_KEY=cEdxLTZad0JNTFRCa0V3elVjNlQ6QTFtenJKWVpaUktxOUJJcnJOdVdHZw==

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Secret key for signing JWT tokens (7-day expiry, refreshed on activity)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CRITICAL: Change this in production — never commit your real secret
JWT_SECRET=your-secret-key-here

# ============================================================================
# OLLAMA SLM CONFIGURATION
# ============================================================================
# Host URL for local Ollama instance running the anonymizer model
# The anonymizer MUST run before any text is sent to external APIs
# Pull the model first: ollama pull hf.co/eternisai/anonymizer-0.6b-q4_k_m-gguf
OLLAMA_HOST=http://localhost:11434

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string for account data (email + password hash only)
# Format: postgresql://user:password@host:port/database
# NOTE: Only email and bcrypt password hash are stored — no names, no DOB
DATABASE_URL=postgresql://echo_user:echo_password@localhost:5432/echo

# ============================================================================
# BACKEND SERVER CONFIGURATION
# ============================================================================
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8000

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Public API URL for Next.js — must use NEXT_PUBLIC_ prefix for client-side access
# Points to the FastAPI backend (docker-compose: http://backend:8000)
# For local dev without Docker: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# PRIVACY NOTES
# ============================================================================
# 1. Raw thought text is NEVER logged or persisted on the server
# 2. The anonymizer (Anonymizer SLM 0.6B via Ollama) runs FIRST — raw text
#    is discarded immediately after anonymization, never written to disk or logs
# 3. NanoGPT API (qwen3.5-122b-a10b) only receives anonymized text, never raw user input
# 4. Elasticsearch stores anonymized thoughts with NO user identifiers
# 5. Account data (email + bcrypt hash) is stored separately from thoughts
# 6. Theme categories link accounts to emotional topics, NOT raw text
# 7. "What helped" advice goes through the same anonymization pipeline
# 8. IP addresses are never stored or logged in any environment
